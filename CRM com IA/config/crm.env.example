# CRM Admin — variáveis de ambiente
# Copie para crm.env e preencha. NUNCA commite crm.env.

# desenvolvimento | homologacao | producao
CRM_AMBIENTE=desenvolvimento

# --- Supabase (projeto FerriBor; preencher com as credenciais da conta FerriBor) ---
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# Somente servidor (Worker / Edge Functions) — NÃO usar no React
SUPABASE_SERVICE_ROLE_KEY=

# Referência para CLI: supabase link --project-ref
SUPABASE_PROJECT_REF=

# --- E-mail (Resend) — fase E2+ ---
# RESEND_API_KEY=

# --- Evolution API (WhatsApp) — fase E1+ ---
# EVOLUTION_API_URL=https://whatsapp-api-evolution-go.SEU-HOST.easypanel.host
# EVOLUTION_API_KEY=
# EVOLUTION_INSTANCE_NAME=inforhealth

# --- Mercado Pago — fase E2+ (Worker também usa wrangler secret) ---
# MERCADOPAGO_PUBLIC_KEY=
# MERCADOPAGO_ACCESS_TOKEN=
# MERCADOPAGO_MODO=sandbox
